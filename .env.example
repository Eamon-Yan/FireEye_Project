# ============================================================
# 火瞳 (FireEye) 系统环境变量配置
# 复制此文件为 .env 并填入实际值
# cp .env.example .env
# ============================================================

# --- 后端 API 配置 ---
# Fire-Eye 后端服务地址（Docker 内用服务名，宿主机用 localhost）
FIRE_EYE_API_URL=http://fire-eye-backend:8000/api/v1

# 🔴 必填：后端 API 密钥（从后端管理员获取）
FIRE_EYE_API_KEY=your-fireeye-api-key-here

# --- Docker 网络适配 ---
# 当插件在 Docker 内、后端在宿主机时，自动重写 localhost → host.docker.internal
# 一般无需手动设置，除非要强制指定
# FIRE_EYE_BACKEND_HOST=host.docker.internal
# FIRE_EYE_BACKEND_PORT=8000

# --- 日志 ---
# LOG_LEVEL=INFO

# --- 数据库（后端使用，插件无需设置） ---
# NEO4J_URI=bolt://neo4j:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=your-neo4j-password
# REDIS_URL=redis://redis:6379/0
