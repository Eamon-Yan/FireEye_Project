# 使用官方 Node.js 18 镜像
FROM node:18-alpine

# 设置工作目录
WORKDIR /app

# 复制 package 文件
COPY package*.json ./

# 安装依赖
RUN npm ci

# 暴露端口
EXPOSE 3000

# 健康检查
HEALTHCHECK --interval=30s --timeout=30s --start-period=10s --retries=5 \
    CMD wget -qO- http://127.0.0.1:3000 || exit 1

# 开发模式启动命令
CMD ["npm", "run", "dev", "--", "--hostname", "0.0.0.0", "--port", "3000"]
